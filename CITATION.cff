    given-names: Sia
    email: siavash.ghelichkhan@anu.edu.au
    website: "https://sia-g.com"
repository-code: "https://github.com/g-adopt/austrata"
url: "https://github.com/g-adopt/austrata"
license: MIT
version: 0.1.0
keywords:
  - geoscience australia
  - boreholes
  - hydrogeology
  - stratigraphy
  - geospatial
